# copy this file to `.env` and fill in your real values
# .env is gitignored — never commit it

# your instagram business or creator account id
# find it via: graph.facebook.com/v19.0/me/accounts?fields=instagram_business_account&access_token=YOUR_TOKEN
IG_BUSINESS_ACCOUNT_ID=

# long-lived meta graph api access token (60 day expiry)
# see README for how to generate
META_TOKEN=

# how far back to pull, in days (default 90)
DAYS_BACK=90

# notion integration token (optional, only needed for notion sync)
# get from: notion.so/my-integrations
NOTION_TOKEN=

# notion database id (optional, only needed for notion sync)
# get from your database URL: notion.so/workspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=
